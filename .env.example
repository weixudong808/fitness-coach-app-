# Supabase配置
# 请在注册Supabase后，将这里的值替换成你的项目信息
# 在Supabase项目设置 -> API 中可以找到这些值

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# 管理员令牌（必须与 Supabase Edge Function 的 ADMIN_TOKEN 一致）
# 生产环境必须设置强密码，不要使用默认值
# 建议使用随机生成的长密码（至少32位）
VITE_ADMIN_TOKEN=your_strong_admin_password

# 注意：
# 1. 复制此文件为 .env.local 并填写实际值
# 2. VITE_ADMIN_TOKEN 必须与 Supabase 的 ADMIN_TOKEN 环境变量一致
# 3. 不要将 .env.local 提交到 Git
