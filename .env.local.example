# Supabase 配置文件
#
# 这个文件包含后台脚本所需的配置
# ⚠️ 注意：这些密钥权限很大，请妥善保管，不要泄露！
#
# 使用方法：
# 1. 复制这个文件为 .env.local
# 2. 将下面的配置替换为真实的值
# 3. 保存文件
#
# 安全提示：
# - .env.local 已经在 .gitignore 中，不会被提交到 Git
# - 只在本地开发环境使用
# - 不要分享给其他人

# ============================================
# 1. Supabase Service Role Key（必需）
# ============================================
# 用于后台脚本，可以绕过 RLS 策略
#
# 如何获取：
# 1. 登录 Supabase Dashboard: https://supabase.com/dashboard
# 2. 选择你的项目
# 3. 进入 Settings > API
# 4. 找到 "service_role" 密钥（不是 "anon" 密钥）
# 5. 点击 "Reveal" 显示密钥
# 6. 复制密钥到下面

SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBwandrcXRiZ2RwZWFtemJod3RhIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MjM1NDQyMCwiZXhwIjoyMDg3OTMwNDIwfQ.OWG4Ze6-og5C63eKtlYMwLBm-_Spo6Dt709lvORJsmg

# ============================================
# 2. 教练 ID（必需）
# ============================================
# 你的教练账号 ID，用于创建训练计划和模板
#
# 如何获取：
# 方法1 - 从前端获取（推荐）：
#   1. 登录健身教练管理系统
#   2. 打开浏览器开发者工具（F12）
#   3. 在控制台输入：localStorage.getItem('sb-ppjwkqtbgdpeamzbhwta-auth-token')
#   4. 找到返回的 JSON 中的 user.id 字段
#
# 方法2 - 从数据库查询：
#   1. 登录 Supabase Dashboard
#   2. 进入 Table Editor > auth.users
#   3. 找到你的教练账号，复制 id 字段
#
# 示例：COACH_ID=c4eb3729-7040-4b02-b6a0-a796340835f9

COACH_ID=your_coach_id_here
